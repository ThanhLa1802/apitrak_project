# GeoDjango / GDAL on Windows (Anaconda)
# Only needed if Django cannot auto-discover the DLLs.
# After: conda install -c conda-forge gdal
# Find your conda env path with: conda info --envs
# Example (replace <env_name>):
GDAL_LIBRARY_PATH=C:\Users\thanh\anaconda3\envs\mywork\Library\bin\gdal.dll
GEOS_LIBRARY_PATH=C:\Users\thanh\anaconda3\envs\mywork\Library\bin\geos_c.dll
PROJ_LIBRARY_PATH=C:\Users\thanh\anaconda3\envs\mywork\Library\bin\proj_9_5.dll
